{
  "info": {
    "name": "Bid Service - Auction Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3002" },
    { "key": "bid_id",   "value": "1" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": { "method": "GET", "url": "{{base_url}}/health" }
    },
    {
      "name": "Bids",
      "item": [
        {
          "name": "Create Bid",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) pm.collectionVariables.set('bid_id', res.data.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/bids",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"auction_id\": 1,\n  \"user_id\": 1,\n  \"amount\": 150.00\n}"
            }
          }
        },
        {
          "name": "Get All Bids",
          "request": { "method": "GET", "url": "{{base_url}}/bids" }
        },
        {
          "name": "Get Bids by Auction",
          "request": { "method": "GET", "url": "{{base_url}}/bids?auction_id=1" }
        },
        {
          "name": "Get Bids by Status",
          "request": { "method": "GET", "url": "{{base_url}}/bids?status=pending" }
        },
        {
          "name": "Get Bid by ID",
          "request": { "method": "GET", "url": "{{base_url}}/bids/{{bid_id}}" }
        },
        {
          "name": "Update Bid Amount",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/bids/{{bid_id}}/amount",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 200.00\n}"
            }
          }
        },
        {
          "name": "Accept Bid",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/bids/{{bid_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            }
          }
        },
        {
          "name": "Reject Bid",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/bids/{{bid_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            }
          }
        },
        {
          "name": "Cancel Bid",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/bids/{{bid_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\"\n}"
            }
          }
        },
        {
          "name": "Delete Bid",
          "request": { "method": "DELETE", "url": "{{base_url}}/bids/{{bid_id}}" }
        }
      ]
    },
    {
      "name": "Bid Logs",
      "item": [
        {
          "name": "Get Logs by Bid",
          "request": { "method": "GET", "url": "{{base_url}}/bids/{{bid_id}}/logs" }
        },
        {
          "name": "Get All Logs",
          "request": { "method": "GET", "url": "{{base_url}}/logs" }
        },
        {
          "name": "Get Logs by Action",
          "request": { "method": "GET", "url": "{{base_url}}/logs?action=created" }
        }
      ]
    }
  ]
}
